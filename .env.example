# ── Web Push (background notifications) ──────────────────────────────
# Only the PRIVATE key is required to enable sending. A default public key is
# shipped in the code; set VITE_VAPID_PUBLIC_KEY only if you regenerate the pair
# (npx web-push generate-vapid-keys).
VAPID_PRIVATE_KEY=
# VITE_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Protects the /api/send cron endpoint. Set to any long random string.
# Vercel Cron automatically sends this as a Bearer token.
CRON_SECRET=

# Subscription store — a Vercel KV integration provides these automatically.
# If using Upstash directly, set UPSTASH_REDIS_REST_URL / _TOKEN instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
